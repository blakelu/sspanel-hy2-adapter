ADAPTER_AUTH_TOKEN=replace-with-a-random-token
SSPANEL_BASE_URL=https://panel.example.com
SSPANEL_MU_KEY=replace-with-sspanel-mukey
SSPANEL_NODE_ID=1
HY2_STATS_SECRET=replace-with-a-different-random-secret

# 独立 Docker HY2 部署参数
HY2_PUBLIC_PORT=8443
# 服务器上的项目绝对路径；port-sync 容器需要以相同路径挂载项目。
HOST_PROJECT_DIR=/opt/sspanel-hy2-adapter
COMPOSE_PROJECT_NAME=sspanel-hy2-adapter
PORT_SYNC_INTERVAL=30
# 自动同步只接受该范围内的面板端口，建议按防火墙放行范围收紧。
HY2_ALLOWED_PORT_MIN=1024
HY2_ALLOWED_PORT_MAX=65535
ADAPTER_DEBUG_PORT=18080
HY2_STATS_DEBUG_PORT=19999

# database 模式才需要以下变量
SSPANEL_DB_HOST=127.0.0.1
SSPANEL_DB_NAME=sspanel
SSPANEL_DB_USER=sspanel_adapter
SSPANEL_DB_PASSWORD=replace-with-database-password
